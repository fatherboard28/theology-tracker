<file path=".air.toml">
root = "."
tmp_dir = "tmp"

[build]
  # templ generate must run before go build so *_templ.go files are fresh.
  cmd = "templ generate && go build -o ./tmp/theology-tracker ./cmd/server"
  bin = "./tmp/theology-tracker"
  delay = 500

  # Watch .templ files as well as .go files.
