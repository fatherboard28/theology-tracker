<file path="internal/templates/pages/courses/detail.templ">
package courses

import (
	"fmt"
	"strconv"
	"theology-tracker/internal/models"
	"theology-tracker/internal/templates/components"
	"theology-tracker/internal/templates/layout"
)

templ Detail(course *models.CourseWithProgress, units []models.UnitWithProgress) {
	@layout.Base(course.Title) {
		<div class="page-header">
			<div>
				<div class="flex items-center gap-2" style="margin-bottom: 4px;">
					<a href="/courses" class="text-muted text-sm">← Courses</a>
				</div>
				<div class="flex items-center gap-2">
					<h1>{ course.Title }</h1>
					@components.CourseStatusBadge(course.Status)
				</div>
				if course.Description != "" {
					<p class="page-header__subtitle">{ course.Description }</p>
				}
			</div>
			<div class="flex gap-2">
				<a
					href={ templ.SafeURL(fmt.Sprintf("/courses/%d/edit", course.ID)) }
					class="btn btn--secondary"
				>Edit</a>
				@courseStatusControls(course)
			</div>
		</div>
		<!-- Progress -->
		<div class="card" style="margin-bottom: 24px;">
			<div class="flex items-center justify-between" style="margin-bottom: 8px;">
				<span class="text-sm">
					{ strconv.Itoa(course.CompletedWorkItems) } of { strconv.Itoa(course.TotalWorkItems) } items complete
				</span>
				<span class="text-sm text-muted">{ strconv.Itoa(course.ProgressPercent()) }%</span>
			</div>
			<div class="progress">
				<div class="progress__bar" style={ fmt.Sprintf("width: %d%%", course.ProgressPercent()) }></div>
			</div>
			<div class="flex gap-4 mt-4">
				if course.StartDate != nil {
					<span class="text-sm text-muted">Started: { *course.StartDate }</span>
				}
				if course.TargetCompletionDate != nil {
					<span class="text-sm text-muted">Target: { *course.TargetCompletionDate }</span>
				}
				if course.ActualCompletionDate != nil {
					<span class="text-sm text-muted">Completed: { *course.ActualCompletionDate }</span>
				}
			</div>
		</div>
		<!-- Units -->
		<div class="flex items-center justify-between mb-4">
			<h2>Units</h2>
			<a
				href={ templ.SafeURL(fmt.Sprintf("/courses/%d/units/new", course.ID)) }
				class="btn btn--primary btn--sm"
			>+ Add Unit</a>
		</div>
		if len(units) == 0 {
			<div class="empty-state">
				<p class="empty-state__title">No units yet</p>
				<p class="empty-state__body">Units break the course into manageable sections.</p>
				<a
					href={ templ.SafeURL(fmt.Sprintf("/courses/%d/units/new", course.ID)) }
					class="btn btn--primary"
				>+ Add Unit</a>
			</div>
		} else {
			<ul
				class="unit-list"
				data-sortable
				data-sortable-url={ fmt.Sprintf("/courses/%d/units/reorder", course.ID) }
				style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 8px;"
			>
				for _, u := range units {
					@unitRow(u, course.ID)
				}
			</ul>
		}
	}
}

templ courseStatusControls(course *models.CourseWithProgress) {
	switch course.Status {
	case models.CourseStatusActive:
		<button
			class="btn btn--secondary btn--sm"
			hx-post={ fmt.Sprintf("/courses/%d/status", course.ID) }
			hx-vals={ `{"status":"Paused"}` }
			hx-target="body"
			hx-push-url="true"
		>Pause</button>
		<button
			class="btn btn--secondary btn--sm"
			hx-post={ fmt.Sprintf("/courses/%d/status", course.ID) }
			hx-vals={ `{"status":"Complete"}` }
			hx-target="body"
			hx-push-url="true"
			hx-confirm="Mark this course complete?"
		>Mark Complete</button>
	case models.CourseStatusPaused:
		<button
			class="btn btn--secondary btn--sm"
			hx-post={ fmt.Sprintf("/courses/%d/status", course.ID) }
			hx-vals={ `{"status":"Active"}` }
			hx-target="body"
			hx-push-url="true"
		>Resume</button>
		<button
			class="btn btn--secondary btn--sm"
			hx-post={ fmt.Sprintf("/courses/%d/status", course.ID) }
			hx-vals={ `{"status":"Complete"}` }
			hx-target="body"
			hx-push-url="true"
			hx-confirm="Mark this course complete?"
		>Mark Complete</button>
	case models.CourseStatusComplete:
		<button
			class="btn btn--secondary btn--sm"
			hx-post={ fmt.Sprintf("/courses/%d/status", course.ID) }
			hx-vals={ `{"status":"Active"}` }
			hx-target="body"
			hx-push-url="true"
			hx-confirm="Reopen this course?"
		>Reopen</button>
	}
}

templ unitRow(u models.UnitWithProgress, courseID int64) {
	<li
		class="card"
		data-id={ strconv.FormatInt(u.ID, 10) }
		style="display: flex; align-items: center; gap: 12px; padding: 16px;"
	>
		<span class="drag-handle" title="Drag to reorder">
			<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
				<rect x="3" y="4" width="10" height="1.5" rx="1"/>
				<rect x="3" y="7.25" width="10" height="1.5" rx="1"/>
				<rect x="3" y="10.5" width="10" height="1.5" rx="1"/>
			</svg>
		</span>
		<div style="flex: 1; min-width: 0;">
			<div class="flex items-center gap-2" style="margin-bottom: 4px;">
				<span class="text-sm" style="font-weight: 600;">{ u.Title }</span>
				if u.IsComplete() {
					<span class="badge badge--complete">Done</span>
				}
			</div>
			if u.TotalWorkItems > 0 {
				<div class="flex items-center gap-2">
					<div class="progress" style="width: 120px;">
						<div class="progress__bar" style={ fmt.Sprintf("width: %d%%", u.ProgressPercent()) }></div>
					</div>
					<span class="text-xs text-muted">
						{ strconv.Itoa(u.CompletedWorkItems) }/{ strconv.Itoa(u.TotalWorkItems) }
					</span>
				</div>
			}
		</div>
		if u.TargetCompletionDate != nil {
			<span class="text-xs text-muted">Due { *u.TargetCompletionDate }</span>
		}
		<div class="flex gap-2">
			<a
				href={ templ.SafeURL(fmt.Sprintf("/courses/%d/units/%d/edit", courseID, u.ID)) }
				class="btn btn--ghost btn--sm"
			>Edit</a>
			<button
				class="btn btn--danger btn--sm btn--ghost"
				hx-delete={ fmt.Sprintf("/courses/%d/units/%d", courseID, u.ID) }
				hx-confirm="Delete this unit and all its work items? This cannot be undone."
				hx-target="body"
				hx-push-url="true"
			>Delete</button>
		</div>
	</li>
}
</file>

<file path="internal/templates/pages/courses/forms.templ">
package courses

import (
	"fmt"
	"theology-tracker/internal/templates/layout"
)

// CourseFormData is populated by the handler for both create and edit views.
type CourseFormData struct {
	IsNew       bool
	CourseID    int64
	Title       string
	Description string
	Status      string
	StartDate   string
	TargetDate  string
	Error       string
}

// UnitFormData is populated by the handler for both create and edit unit views.
type UnitFormData struct {
	IsNew      bool
	CourseID   int64
	UnitID     int64
	Title      string
	Desc       string
	TargetDate string
	Error      string
}

// ── Course form ───────────────────────────────────────────────────────────────

templ Form(data CourseFormData) {
	@layout.Base(courseFormPageTitle(data)) {
		<div class="page-header">
			<div>
				<div class="flex items-center gap-2" style="margin-bottom: 4px;">
					<a href="/courses" class="text-muted text-sm">← Courses</a>
				</div>
				<h1>{ courseFormPageTitle(data) }</h1>
			</div>
		</div>
		<div class="card" style="max-width: 640px;">
			if data.Error != "" {
				<div class="alert alert--error">{ data.Error }</div>
			}
			if data.IsNew {
				<form method="POST" action="/courses">
					@courseFormFields(data)
				</form>
			} else {
				<form
					method="POST"
					action={ templ.SafeURL(fmt.Sprintf("/courses/%d", data.CourseID)) }
				>
					<!-- Method override for PUT via plain POST -->
					<input type="hidden" name="_method" value="PUT"/>
					@courseFormFields(data)
				</form>
			}
		</div>
	}
}

templ courseFormFields(data CourseFormData) {
	<div class="form-group">
		<label for="title">Title <span style="color: var(--color-danger);">*</span></label>
		<input
			type="text"
			id="title"
			name="title"
			value={ data.Title }
			placeholder="e.g. Systematic Theology I"
			required
			autofocus
		/>
	</div>
	<div class="form-group">
		<label for="description">Description</label>
		<textarea
			id="description"
			name="description"
			rows="3"
			placeholder="Optional notes about this course"
		>{ data.Description }</textarea>
	</div>
	if !data.IsNew {
		<div class="form-group">
			<label for="status">Status</label>
			<select id="status" name="status">
				<option value="Active" selected?={ data.Status == "Active" }>Active</option>
				<option value="Paused" selected?={ data.Status == "Paused" }>Paused</option>
				<option value="Complete" selected?={ data.Status == "Complete" }>Complete</option>
			</select>
		</div>
	}
	<div class="form-group">
		<label for="start_date">Start Date</label>
		<input
			type="date"
			id="start_date"
			name="start_date"
			value={ data.StartDate }
		/>
		<p class="form-hint">Optional</p>
	</div>
	<div class="form-group">
		<label for="target_completion_date">Target Completion Date</label>
		<input
			type="date"
			id="target_completion_date"
			name="target_completion_date"
			value={ data.TargetDate }
		/>
		<p class="form-hint">Optional</p>
	</div>
	<div class="flex gap-2 mt-6">
		<button type="submit" class="btn btn--primary">
			if data.IsNew {
				Create Course
			} else {
				Save Changes
			}
		</button>
		<a href="/courses" class="btn btn--secondary">Cancel</a>
	</div>
}

// ── Unit form ─────────────────────────────────────────────────────────────────

templ UnitForm(data UnitFormData) {
	@layout.Base(unitFormPageTitle(data)) {
		<div class="page-header">
			<div>
				<div class="flex items-center gap-2" style="margin-bottom: 4px;">
					<a
						href={ templ.SafeURL(fmt.Sprintf("/courses/%d", data.CourseID)) }
						class="text-muted text-sm"
					>← Course</a>
				</div>
				<h1>{ unitFormPageTitle(data) }</h1>
			</div>
		</div>
		<div class="card" style="max-width: 640px;">
			if data.Error != "" {
				<div class="alert alert--error">{ data.Error }</div>
			}
			if data.IsNew {
				<form
					method="POST"
					action={ templ.SafeURL(fmt.Sprintf("/courses/%d/units", data.CourseID)) }
				>
					@unitFormFields(data)
				</form>
			} else {
				<form
					method="POST"
					action={ templ.SafeURL(fmt.Sprintf("/courses/%d/units/%d", data.CourseID, data.UnitID)) }
				>
					<input type="hidden" name="_method" value="PUT"/>
					@unitFormFields(data)
				</form>
			}
		</div>
	}
}

templ unitFormFields(data UnitFormData) {
	<div class="form-group">
		<label for="title">Title <span style="color: var(--color-danger);">*</span></label>
		<input
			type="text"
			id="title"
			name="title"
			value={ data.Title }
			placeholder="e.g. Introduction to Soteriology"
			required
			autofocus
		/>
	</div>
	<div class="form-group">
		<label for="description">Description</label>
		<textarea
			id="description"
			name="description"
			rows="3"
			placeholder="Optional notes about this unit"
		>{ data.Desc }</textarea>
	</div>
	<div class="form-group">
		<label for="target_completion_date">Target Completion Date</label>
		<input
			type="date"
			id="target_completion_date"
			name="target_completion_date"
			value={ data.TargetDate }
		/>
		<p class="form-hint">Optional</p>
	</div>
	<div class="flex gap-2 mt-6">
		<button type="submit" class="btn btn--primary">
			if data.IsNew {
				Add Unit
			} else {
				Save Changes
			}
		</button>
		<a
			href={ templ.SafeURL(fmt.Sprintf("/courses/%d", data.CourseID)) }
			class="btn btn--secondary"
		>Cancel</a>
	</div>
}

// ── Helpers ───────────────────────────────────────────────────────────────────

func courseFormPageTitle(data CourseFormData) string {
	if data.IsNew {
		return "New Course"
	}
	return "Edit Course"
}

func unitFormPageTitle(data UnitFormData) string {
	if data.IsNew {
		return "Add Unit"
	}
	return "Edit Unit"
}
</file>

<file path="internal/templates/pages/courses/list.templ">
package courses

import (
	"fmt"
	"strconv"
	"theology-tracker/internal/models"
	"theology-tracker/internal/templates/components"
	"theology-tracker/internal/templates/layout"
)

templ List(courses []models.CourseWithProgress) {
	@layout.Base("Courses") {
		<div class="page-header">
			<div>
				<h1>Courses</h1>
				<p class="page-header__subtitle">
					{ strconv.Itoa(len(courses)) } course(s) total
				</p>
			</div>
			<a href="/courses/new" class="btn btn--primary">+ New Course</a>
		</div>
		if len(courses) == 0 {
			<div class="empty-state">
				<p class="empty-state__title">No courses yet</p>
				<p class="empty-state__body">Add your first course to get started.</p>
				<a href="/courses/new" class="btn btn--primary">+ New Course</a>
			</div>
		} else {
			<div class="course-list">
				for _, c := range courses {
					@courseCard(c)
				}
			</div>
		}
	}
}

templ courseCard(c models.CourseWithProgress) {
	<div class="card" data-course-id={ strconv.FormatInt(c.ID, 10) }>
		<div class="card__header">
			<div class="flex items-center gap-2">
				<h2 class="card__title">
					<a href={ templ.SafeURL(fmt.Sprintf("/courses/%d", c.ID)) }>
						{ c.Title }
					</a>
				</h2>
				@components.CourseStatusBadge(c.Status)
			</div>
			<div class="flex gap-2">
				<a
					href={ templ.SafeURL(fmt.Sprintf("/courses/%d/edit", c.ID)) }
					class="btn btn--secondary btn--sm"
				>Edit</a>
				<button
					class="btn btn--danger btn--sm"
					hx-delete={ fmt.Sprintf("/courses/%d", c.ID) }
					hx-target="closest [data-course-id]"
					hx-swap="outerHTML"
					hx-confirm="Delete this course and all its units? This cannot be undone."
				>Delete</button>
			</div>
		</div>
		if c.Description != "" {
			<p class="text-muted text-sm mb-4">{ c.Description }</p>
		}
		<div class="flex items-center gap-4" style="margin-bottom: 8px;">
			<span class="text-sm text-muted">
				{ strconv.Itoa(c.CompletedWorkItems) }/{ strconv.Itoa(c.TotalWorkItems) } items complete
			</span>
			<span class="text-sm text-muted">{ strconv.Itoa(c.ProgressPercent()) }%</span>
		</div>
		<div class="progress">
			<div class="progress__bar" style={ fmt.Sprintf("width: %d%%", c.ProgressPercent()) }></div>
		</div>
		if c.TargetCompletionDate != nil {
			<p class="text-sm text-muted mt-4">Target: { *c.TargetCompletionDate }</p>
		}
	</div>
}
</file>

<file path="scripts/init-proj.sh">
#!/bin/bash

# 1. Download the four JS libraries into static/js/
#    (do this once — they're vendored so the app works offline)
curl -o static/js/htmx.min.js https://unpkg.com/htmx.org@1.9.12/dist/htmx.min.js
curl -o static/js/alpine.min.js https://unpkg.com/alpinejs@3.14.1/dist/cdn.min.js
curl -o static/js/sortable.min.js https://unpkg.com/sortablejs@1.15.2/Sortable.min.js
curl -o static/js/marked.min.js https://unpkg.com/marked@12.0.0/marked.min.js

# 2. Pull dependencies and generate go.sum
go mod tidy

# 3. Generate the Templ Go files
templ generate

# 4. Run with hot reload
air
</file>

